# Rust backend environment example

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
COOKIE_SAMESITE=Lax

# Admin
ADMIN_TOKEN=your_admin_token
ALLOW_INSECURE_ADMIN_DEV=0
DISABLE_ADMIN_SCRIPTS=0
SOLANA_AMM_ADMIN_STRICT=0
# Server-derived KEK mode is disabled by default. Keep 0 except controlled emergency exceptions.
ENABLE_SERVER_KEK=0

# EVM quotes/fallback
ZEROX_API_KEY=your_0x_api_key
# Fallback provider: zeroex_compat | oneinch
FALLBACK_AGGREGATOR_PROVIDER=zeroex_compat
# For oneinch provider, leave empty to use secure default: https://api.1inch.dev/swap/v6.0
FALLBACK_AGGREGATOR_URL=
FALLBACK_AGGREGATOR_API_KEY=
# oneinch typically uses Authorization: Bearer <key>; keep x-api-key only for zeroex-compatible fallbacks
FALLBACK_AGGREGATOR_API_HEADER=x-api-key
FALLBACK_AGGREGATOR_QUOTE_PATH=/swap/allowance-holder/quote
FALLBACK_AGGREGATOR_PRICE_PATH=/swap/allowance-holder/price
FALLBACK_AGGREGATOR_VERSION=

# Solana/Jupiter
JUPITER_API_KEY=your_jupiter_api_key
JUPITER_API_URL=https://api.jup.ag/swap/v1
SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_AMM_PROGRAM_ID=
SOLANA_DEPLOYER_KEYPAIR=
SOLANA_AMM_FEE_BPS=30
SOLANA_TOKEN_A_SYMBOL=TSTA
SOLANA_TOKEN_B_SYMBOL=TSTB
SOLANA_TOKEN_A_DECIMALS=6
SOLANA_TOKEN_B_DECIMALS=6
SOLANA_LIQUIDITY_A=100000
SOLANA_LIQUIDITY_B=100000

# Allowlists
EXTERNAL_API_ALLOWLIST=api.0x.org,api.jup.ag,api.1inch.dev
ALLOWED_PROXY_HOSTS=api.coingecko.com,api.etherscan.io,api.0x.org,api.jup.ag,api.1inch.dev
ALLOWED_EXTERNAL_HOSTS=api.0x.org,api.jup.ag,api.1inch.dev
RPC_URL_ALLOWLIST=rpc.ankr.com,ethereum.publicnode.com
RPC_MAX_REQUEST_BODY_BYTES=262144
RPC_MAX_BATCH_ITEMS=25
RPC_METHOD_RATE_LIMIT_MAX_REQUESTS=60
RPC_METHOD_RATE_LIMIT_WINDOW_MS=60000
INFRA_STORE_BACKEND=memory
INFRA_REDIS_URL=redis://127.0.0.1:6379/
INFRA_REDIS_KEY_PREFIX=elementa
INFRA_REDIS_REQUIRED=0
INFRA_REDIS_CONNECT_TIMEOUT_MS=800
INFRA_REDIS_COMMAND_TIMEOUT_MS=500

# OAuth / cloud recovery
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/google/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
APPLE_OAUTH_REDIRECT_URI=http://localhost:5173

# Session / KEK secrets
SESSION_JWT_SECRET=change_me_to_a_long_random_secret
CLOUD_KEK_SECRET=change_me_to_a_long_random_secret

# Cloud recovery store: file|sqlite
CLOUD_RECOVERY_STORE=file
# CLOUD_RECOVERY_SQLITE_PATH=./state/cloud_recovery.sqlite3
